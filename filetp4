pipeline {

    agent any

    tools {
        maven 'maven3'
    }
    /*
    Déclaration des paramètres.
    Ils apparaîtront dans Jenkins avec l'option :
    "Build with Parameters"
    */

    parameters {

        string(
            name: 'NAME',
            defaultValue: 'DevOps User',
            description: 'Please tell me your name'
        )

        text(
            name: 'DESC',
            defaultValue: 'Pipeline CI/CD Jenkins GitHub',
            description: 'Description du Job'
        )

        booleanParam(
            name: 'SKIP_TEST',
            defaultValue: false,
            description: 'Skip running Tests ?'
        )

        choice(
            name: 'BRANCH',
            choices: [
                'main',
                'dev',
                'test'
            ],
            description: 'Choose Git branch'
        )

        password(
            name: 'SONAR_SERVER_PWD',
            description: 'Enter SONAR password'
        )

    }


    environment {

        APP_NAME  = "web-app"
        DOCKER_IMAGE = "mydockerhub/web-app"
        SONAR_URL = "http://localhost:9000"
        SNYK_EXE = "C:\\ProgramData\\chocolatey\\bin\\snyk.exe"
    }


    stages {


        /*
        Affichage des paramètres envoyés
        par l'utilisateur
        */

        stage('01 - PRINT PARAMETERS') {

            steps {

                echo "Hello ${params.NAME}"

                echo """
                Job Description:
                ${params.DESC}
                """

                echo "Branch Selected : ${params.BRANCH}"

                echo "Skip Test : ${params.SKIP_TEST}"

            }

        }


        /*
        Récupération du projet depuis Github
        */

        stage('02 - CHECKOUT GITHUB') {

            steps {

                echo "Downloading source code..."

                git branch: "${params.BRANCH}",
                    url: 'https://github.com/Sariarii/E5_tarbes_DevSecOps_juin_2026.git'

            }

        }


        /*
        Compilation de l'application
        FIX : utilisation de bat au lieu de sh (Jenkins sur Windows)
        FIX : les commandes bat ne supportent pas la syntaxe shell Unix
        */

        stage('03 - BUILD APPLICATION') {

            steps {

                echo "Building Application"

                bat "echo Compilation en cours..."

                bat "mvn clean package"

            }

        }


        /*
        Tests unitaires
        Le stage sera ignoré si SKIP_TEST=true
        */

        stage('04 - RUN TESTS') {

            when {

                expression {
                    return params.SKIP_TEST == false
                }

            }

            steps {

                echo "Running Tests"

                bat "mvn test"

            }

        }


        /*
        Analyse qualité SonarQube
        FIX : les arguments mvn sur une seule ligne (pas de \ sous bat)
        */

        /*stage('05 - SONARQUBE ANALYSIS') {

            steps {

                echo "Scanning source code"

                bat "mvn sonar:sonar -Dsonar.host.url=${SONAR_URL} -Dsonar.login=${params.SONAR_SERVER_PWD}"

            }

        }*/


        /*
        Création image Docker
        */

        stage('06 - DOCKER BUILD') {

            steps {

                echo "Creating Docker image"

                bat "docker build -t ${DOCKER_IMAGE}:latest ."

            }

        }
        stage('07 - SECURITY SCAN TRIVY') {
    steps {
        echo "Scanning Docker image for vulnerabilities"

        // Scan de l'image avec Trivy - affiche uniquement HIGH et CRITICAL
        bat "trivy image --severity HIGH,CRITICAL ${DOCKER_IMAGE}:latest"
    }
}


        /*
        Déploiement
        FIX : || true remplacé par & exit 0 (syntaxe Windows)
        FIX : \ de continuation remplacé par ^ (syntaxe Windows)
              ou commandes séparées
        */

        stage('08 - DEPLOY') {

            steps {

                echo "Deploying Application"

                // Arrêt et suppression du conteneur existant (sans échouer si absent)
                bat "docker stop ${APP_NAME} & exit 0"
                bat "docker rm ${APP_NAME} & exit 0"

                // Lancement du nouveau conteneur
                // FIX : continuation de ligne Windows avec ^
                bat "docker run -d ^" +
                    " --name ${APP_NAME} ^" +
                    " -p 8081:8080 ^" +
                    " ${DOCKER_IMAGE}:latest"

            }

        }

    stage('09 - SNYK CONTAINER SCAN') { 

    when { 

        expression { 

            return params.SKIP_SNYK == false 

        } 

    } 

    steps { 

        echo "Analyse de l'image Docker avec Snyk - mode non bloquant" 

 

        withCredentials([string(credentialsId: 'snyk-token', variable: 'SNYK_TOKEN')]) { 

            bat """ 

            "%SNYK_EXE%" auth %SNYK_TOKEN% 

            "%SNYK_EXE%" container test %DOCKER_IMAGE%:latest ^ 

            --severity-threshold=high || exit /b 0 

            """ 

        } 

    } 

}  

    }



    /*
    Actions exécutées à la fin
    */

    post {

        success {

            echo """

            =========================

            PIPELINE SUCCESS

            Application deployed

            =========================

            """

        }

        failure {

            echo """

            =========================

            PIPELINE FAILED

            Please check logs

            =========================

            """

        }

    }

}
